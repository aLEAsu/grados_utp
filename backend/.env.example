# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://itp_admin:itp_dev_2024@localhost:5432/plataforma_grados

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Email (use localhost:1025 with MailHog for development)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@itp.edu.co

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Digital Signatures
SIGNATURE_PRIVATE_KEY_PATH=./signatures/private-key.pem
SIGNATURE_CERT_PATH=./signatures/certificate.pem

# External APIs
ITP_API_BASE_URL=http://localhost:3001/api
ITP_API_KEY=dev-api-key

# CORS
CORS_ORIGIN=http://localhost:4200

# Logging
LOG_LEVEL=debug
